# EditorConfig is awesome: https://EditorConfig.org

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
insert_final_newline = true
end_of_line = lf
indent_style = space
indent_size = 2
max_line_length = 112
trim_trailing_whitespace = true

[{*.db,*.sql,*.sqlite}]
indent_size = 4
max_line_length = 108

[*.prisma]
indent_size = 2
max_line_length = 108

[{*.py,*.pyi}]
indent_size = 4
max_line_length = 96

[{*.toml,*.yaml}]
indent_size = 2
max_line_length = 96

[{*.rs,*.zig}]
indent_size = 4

[{*.c,*.h,*.cpp,*.hpp,*.cc,*.cxx,*.hh,*.hxx}]
indent_size = 4

[{*.java,*.kt,*.kts,*.scala,*.groovy,*.gradle}]
indent_size = 4

[*.sh,*.fish]
indent_size = 4

[Dockerfile]
indent_size = 4

[*.http,*.ps1]
indent_size = 2

[*.go]
indent_style = tab
indent_size = unset # Allow user-defined tab width

[Makefile]
indent_style = tab
indent_size = unset # Allow user-defined tab width

[CMakeLists.txt]
indent_size = 4

[justfile]
indent_size = 4

[{*.md,*.mdx,*.mdoc}]
indent_size = 2
max_line_length = 108
trim_trailing_whitespace = false

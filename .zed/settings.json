{
  "semantic_tokens": "combined",
  "languages": {
    "CSS": {
      "language_servers": ["tailwindcss-intellisense-css", "!vscode-css-language-server", "..."],
    },
    "SQL": {
      "formatter": {
        "external": {
          "command": "sql-formatter",
        },
      },
    },
    "kulala-http": {
      "formatter": {
        "external": {
          "command": "kulala-fmt",
          "arguments": ["format", "--stdin", "{buffer_path}"],
        },
      },
      "format_on_save": "on",
    },
    "Shell Script": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "shfmt",
          // Change `--indent 2` to match your preferred tab_size
          "arguments": ["--filename", "{buffer_path}", "--indent", "2"],
        },
      },
    },
  },
  "lsp": {
    "kulala-lsp": {
      "binary": {
        "path": "/home/maia/.local/share/pnpm/kulala-ls",
        "arguments": ["--stdio"],
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        // Rust Analyzer settings
        "rustc": { "source": "discover" },
        "assist": { "preferSelf": true, "emitMustUse": true },
        "cargo": { "features": "all", "targetDir": true },
        "check": { "command": "clippy" },
        "checkOnSave": true,
        "imports": {
          "granularity": { "enforce": true, "group": "module" },
          "merge": { "glob": true },
          "preferNoStd": true,
          "preferPrelude": true,
        },
        "inlayHints": { "typeHints": { "enable": true }, "chainingHints": { "enable": true } },
        "rustfmt": { "extraArgs": ["+nightly"] },
        "semanticHighlighting": {
          "doc": { "comment": { "inject": { "enable": true } } },
          "punctuation": { "enable": true, "specialization": { "enable": true } },
        },
        "completion": {
          "autoimport": { "enable": true },
          // "snippets": {
          //   "custom": {
          //     "Arc::new": {
          //       "postfix": "arc",
          //       "body": ["Arc::new(${receiver})"],
          //       "requires": "std::sync::Arc",
          //       "scope": "expr",
          //     },
          //     "Some": {
          //       "postfix": "some",
          //       "body": ["Some(${receiver})"],
          //       "scope": "expr",
          //     },
          //     "Ok": {
          //       "postfix": "ok",
          //       "body": ["Ok(${receiver})"],
          //       "scope": "expr",
          //     },
          //     "Rc::new": {
          //       "postfix": "rc",
          //       "body": ["Rc::new(${receiver})"],
          //       "requires": "std::rc::Rc",
          //       "scope": "expr",
          //     },
          //     "Box::pin": {
          //       "postfix": "boxpin",
          //       "body": ["Box::pin(${receiver})"],
          //       "requires": "std::boxed::Box",
          //       "scope": "expr",
          //     },
          //     "vec!": {
          //       "postfix": "vec",
          //       "body": ["vec![${receiver}]"],
          //       "description": "vec![]",
          //       "scope": "expr",
          //     },
